{
  "name": "voronoi-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "test:pages-build": "VITE_BASE_PATH=/Voronoi/ VITE_ENABLE_PWA=true vite build",
    "validate": "bun run check && bun run build && bun run test:pages-build"
  },
  "dependencies": {
    "@preact/signals": "^2.8.2",
    "preact": "^10.29.0",
    "q5": "^2.1.1",
    "d3-delaunay": "^6.0.4",
    "dat.gui": "^0.7.9"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/dat.gui": "^0.7.10",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
